{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Javrate Downloader",
  "version": "0.1.0",
  "identifier": "tw.stanley.javrate-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Javrate Downloader",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "url": "/"
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["app"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null
    }
  }
}
